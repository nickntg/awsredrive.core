FROM --platform=$BUILDPLATFORM mcr.microsoft.com/dotnet/sdk:8.0 AS build
ARG TARGETPLATFORM
WORKDIR /src
COPY Projects/ ./Projects/
COPY Solutions/ ./Solutions/
COPY Tests/ ./Tests/

RUN dotnet test Tests/AWSRedrive.Tests.Unit/AWSRedrive.Tests.Unit.csproj -c Release
RUN case "$TARGETPLATFORM" in "linux/arm64") echo "linux-arm64" ;; *) echo "linux-x64" ;; esac > /tmp/runtime

FROM build AS console-build
RUN dotnet publish Projects/AWSRedrive.console/AWSRedrive.console.csproj -c Release -r $(cat /tmp/runtime) --self-contained -p:PublishSingleFile=true -o /app

FROM build AS service-build
RUN dotnet publish Projects/AWSRedrive.LinuxService/AWSRedrive.LinuxService.csproj -c Release -r $(cat /tmp/runtime) --self-contained -p:PublishSingleFile=true -o /app

FROM mcr.microsoft.com/dotnet/runtime-deps:8.0-noble-chiseled AS console-image
WORKDIR /app
COPY --from=console-build /app .
EXPOSE 5000
ENTRYPOINT ["./AWSRedrive.console"]

FROM mcr.microsoft.com/dotnet/runtime-deps:8.0-noble-chiseled AS service-image
WORKDIR /app
COPY --from=service-build /app .
EXPOSE 5000
ENTRYPOINT ["./AWSRedrive.LinuxService"]
