<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwExceptions="false">

  <variable name="logDirectory" value="${basedir}/logs"/>

  <targets>
    <target name="logfile" xsi:type="File"
            fileName="${logDirectory}/awsredrive.log"
            archiveEvery="Day"
            archiveFileName="${logDirectory}/awsredrive.{#}.log"
            archiveNumbering="Date"
            archiveDateFormat="yyyy-MM-dd"
            maxArchiveFiles="7">
      <layout xsi:type="JsonLayout" includeEventProperties="true" excludeEmptyProperties="true"
              excludeProperties="Host,Method,Path,PathBase,Scheme,StatusCode">
        <attribute name="@timestamp" layout="${date:universalTime=true:format=yyyy-MM-ddTHH\:mm\:ss.fffZ}" />
        <attribute name="level" layout="${level:upperCase=true}" />
        <attribute name="logger" layout="${logger}" />
        <attribute name="message" layout="${message}" />
        <attribute name="exception" layout="${exception:format=tostring}" />
        <attribute name="application" layout="AWSRedrive" />
        <attribute name="host" layout="${machinename}" />
      </layout>
    </target>

    <target name="logconsole" xsi:type="Console">
      <layout xsi:type="JsonLayout" includeEventProperties="true" excludeEmptyProperties="true">
        <attribute name="@timestamp" layout="${date:universalTime=true:format=yyyy-MM-ddTHH\:mm\:ss.fffZ}" />
        <attribute name="level" layout="${level:upperCase=true}" />
        <attribute name="logger" layout="${logger}" />
        <attribute name="message" layout="${message}" />
        <attribute name="exception" layout="${exception:format=tostring}" />
      </layout>
    </target>
  </targets>

  <rules>
    <!-- Metrics - Info+ -->
    <logger name="Metrics" minlevel="Info" writeTo="logfile" final="true" />
    
    <!-- Microsoft/Kestrel - Discard Debug and below, keep Info+ -->
    <logger name="Microsoft.*" maxlevel="Debug" final="true" />
    <logger name="Microsoft.*" minlevel="Info" writeTo="logfile" final="true" />
    
    <!-- All other loggers - Trace+ (filtering done in EntryLogger) -->
    <logger name="*" minlevel="Trace" writeTo="logfile" />
  </rules>
</nlog>